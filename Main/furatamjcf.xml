<!-- woohoo soham's project (mujoco sim boutta be dope fr)-->


<mujoco model="Soham Furuta Pendulum">
    <compiler angle="degree" coordinate="local" inertiafromgeom="true"/>

    <asset>
        <mesh name="base_mesh" file="base.stl" scale="0.001 0.001 0.001"/>
        <mesh name="legs_mesh" file="legs.stl" scale="0.001 0.001 0.001"/>
        <mesh name="n20_mesh" file="n20.stl" scale="0.001 0.001 0.001"/>
        <mesh name="n20bracket_mesh" file="n20bracket.stl" scale="0.001 0.001 0.001"/>
        
        <mesh name="horiarm_mesh" file="horiarm.stl" scale="0.001 0.001 0.001"/>
        <mesh name="magnetbracket_mesh" file="magnetbracket.stl" scale="0.001 0.001 0.001"/>
        <mesh name="as5600_mesh" file="as5600.stl" scale="0.001 0.001 0.001"/>
        
        <mesh name="pend_mesh" file="pend.stl" scale="0.001 0.001 0.001"/>
        <mesh name="bearing_mesh" file="bearing.stl" scale="0.001 0.001 0.001"/>
        <mesh name="washer_mesh" file="washer.stl" scale="0.001 0.001 0.001"/>
    </asset>

    <worldbody>
        <light diffuse=".5 .5 .5" pos="0 0 3" dir="0 0 -1"/>

        <body name="base_assembly" pos="0 0 0">
            <geom type="mesh" mesh="base_mesh" rgba="0.3 0.3 0.3 1"/>
            <geom type="mesh" mesh="legs_mesh" rgba="0.2 0.2 0.2 1"/>
            <geom type="mesh" mesh="n20bracket_mesh" rgba="0.5 0.5 0.5 1"/>
            <geom type="mesh" mesh="n20_mesh" rgba="0.1 0.1 0.1 1"/>

            <body name="arm_assembly" pos="0 0 0.05">
                <joint name="arm_joint" type="hinge" axis="0 0 1"/>
                <geom type="mesh" mesh="horiarm_mesh" rgba="0 0.4 0.8 1"/>
                <geom type="mesh" mesh="magnetbracket_mesh" rgba="0.7 0.7 0.7 1"/>
                <geom type="mesh" mesh="as5600_mesh" rgba="0 0.8 0 1"/>

                <body name="pendulum_assembly" pos="0.15 0 0">
                    <joint name="pendulum_joint" type="hinge" axis="0 1 0"/>
                    <geom type="mesh" mesh="pend_mesh" rgba="0.8 0 0 1"/>
                    <geom type="mesh" mesh="bearing_mesh" rgba="0.6 0.6 0.6 1"/>
                    <geom type="mesh" mesh="washer_mesh" rgba="0.5 0.5 0.5 1"/>
                </body>
            </body>
         </body>
    </worldbody>
</mujoco>